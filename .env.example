# Postgres (Neon). DATABASE_URL is the pooler (pgbouncer) endpoint used by the app
# at runtime; DIRECT_URL is the non-pooler endpoint used by `prisma migrate`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Better Auth — generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=""

# Where the app lives. Drives Better Auth's trustedOrigins and absolute URLs
# in outbound emails. Dev default below; set per environment in production.
PUBLIC_APP_URL="http://localhost:5173"

# Email
# EMAIL_TRANSPORT=dev    → console.log payloads (no network)
# EMAIL_TRANSPORT=resend → calls Resend (requires RESEND_API_KEY + verified sender)
EMAIL_TRANSPORT="dev"
EMAIL_FROM="ADSAT Ops <noreply@example.com>"
RESEND_API_KEY=""

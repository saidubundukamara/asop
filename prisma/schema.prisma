// ADSAT Staff Operations Platform — Phase 1 schema.
//
// Better Auth canonical tables (User, Account, Session, Verification, RateLimit)
// are emitted by `npm run auth:generate` (a thin wrapper around
// `@better-auth/cli generate --config src/lib/server/auth-cli.ts`). The CLI
// points at auth-cli.ts — not auth.ts — because auth.ts pulls in $app/server
// for the sveltekitCookies plugin, which jiti can't resolve.
//
// Re-run the CLI whenever auth-config.ts changes user.additionalFields or
// rateLimit storage settings; merge any new columns into the User model below
// by hand.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Better Auth canonical (generated; safe to edit columns, not table names) ---

model User {
  id            String   @id
  name          String
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // additionalFields from src/lib/server/auth.ts:
  role         String    @default("staff")
  departmentId String?
  isActive     Boolean   @default(true)
  lastSignInAt DateTime?
  phone        String?
  photoUrl     String?
  timeZone     String?   @default("UTC")

  sessions   Session[]
  accounts   Account[]
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  auditLogs  AuditLog[]

  // Phase 3 — tasks back-relations. Named relations are required because the
  // Task model references User twice (assignee vs assigner).
  tasksAssigned        Task[]            @relation("TaskAssignee")
  tasksCreated         Task[]            @relation("TaskAssigner")
  taskStatusEvents     TaskStatusEvent[]
  taskComments         TaskComment[]
  taskTemplatesCreated TaskTemplate[]    @relation("TaskTemplateCreator")

  // Phase 4 — reports
  reportsAuthored          Report[]         @relation("ReportAuthor")
  reportsReviewing         Report[]         @relation("ReportReviewer")
  reportTemplatesCreated   ReportTemplate[] @relation("ReportTemplateCreator")
  reportComments           ReportComment[]

  // Phase 5 — notifications
  notifications     Notification[]           @relation("UserNotifications")
  notificationPrefs NotificationPreference[] @relation("UserNotifPrefs")
  pushSubscriptions PushSubscription[]       @relation("UserPushSubs")

  @@unique([email])
  @@index([departmentId])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model RateLimit {
  id          String @id
  key         String
  count       Int
  lastRequest BigInt

  @@unique([key])
  @@map("rateLimit")
}

// --- Domain models (hand-written) ---

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  tasks           Task[]
  taskTemplates   TaskTemplate[]
  reportTemplates ReportTemplate[]
}

// Append-only record of sensitive actions (PRD § 11.1, FR-AUDIT-1). Phase 2
// writes the first rows (user invite/edit/role-change/deactivate/reactivate);
// Phase 9 builds the /admin/audit viewer. Always written *inside the same
// $transaction* as the mutation it logs (see src/lib/server/audit.ts) so
// rollback covers both halves.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  targetType String
  targetId   String
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_log")
}

// --- Phase 3 — Tasks (FR-TASK-1..9) ---
//
// Status uses a Prisma enum (not a string like User.role): unlike role,
// task status isn't constrained by Better Auth additionalFields, so an enum
// gives both a generated TS union and a DB-level CHECK.
//
// Description is tiptap-serialized HTML. Sanitize through
// src/lib/server/sanitize.ts on every write before persisting.

enum TaskStatus {
  assigned
  in_progress
  submitted
  completed
  blocked
  cancelled
}

enum TaskPriority {
  low
  medium
  high
}

model TaskTemplate {
  id                  String       @id @default(cuid())
  name                String
  defaultDescription  String?
  defaultPriority     TaskPriority @default(medium)
  defaultDepartmentId String?
  defaultDepartment   Department?  @relation(fields: [defaultDepartmentId], references: [id], onDelete: SetNull)
  dueDateOffsetDays   Int?
  isArchived          Boolean      @default(false)
  createdById         String?
  createdBy           User?        @relation("TaskTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  tasks Task[]

  @@index([isArchived, name])
  @@index([defaultDepartmentId])
  @@map("task_template")
}

model Task {
  id           String        @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus    @default(assigned)
  priority     TaskPriority  @default(medium)
  dueDate      DateTime?
  // Restrict: deactivation (not deletion) is the supported lifecycle for users
  // with live tasks (FR-USER-4). Belt-and-braces in case a future migration
  // accidentally hard-deletes a user.
  assigneeId   String
  assignee     User          @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  assignerId   String?
  assigner     User?         @relation("TaskAssigner", fields: [assignerId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  templateId   String?
  template     TaskTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  completedAt  DateTime?
  // FR-TASK-9 soft delete. 30-day purge cron lands with Phase 5 cron infra.
  deletedAt    DateTime?

  statusEvents TaskStatusEvent[]
  comments     TaskComment[]
  reports      Report[]

  // PRD § 11.3 indexes
  @@index([assigneeId, status])
  @@index([dueDate])
  @@index([assignerId])
  @@index([departmentId, status])
  @@index([deletedAt])
  @@map("task")
}

model TaskStatusEvent {
  id         String      @id @default(cuid())
  taskId     String
  task       Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromStatus TaskStatus?
  toStatus   TaskStatus
  actorId    String?
  actor      User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)
  note       String?
  at         DateTime    @default(now())

  @@index([taskId, at(sort: Desc)])
  @@map("task_status_event")
}

model TaskComment {
  id               String    @id @default(cuid())
  taskId           String
  task             Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId         String?
  author           User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  body             String
  // Resolved on write; Phase 5 reads to dispatch notifications.
  mentionedUserIds String[]
  createdAt        DateTime  @default(now())
  editedAt         DateTime?
  deletedAt        DateTime?

  @@index([taskId, createdAt(sort: Desc)])
  @@map("task_comment")
}

// --- Phase 4 — Reports (FR-REP-1..9) ---

enum ReportStatus {
  draft
  submitted
  under_review
  approved
  needs_revision
}

enum ReportFieldType {
  short_text
  long_text
  number
  date
  datetime
  dropdown
  multi_select
  checkbox
  file
  geolocation
}

// Admin-defined form template. Versioning: if a template that already has
// non-draft Report rows is edited, a new version row is created and the old
// one is deactivated (isActive = false). Reports keep their original templateId
// so they always render against the field definitions they were created with.
model ReportTemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?
  departmentId String?
  // Who reviews reports submitted against this template: "manager" | "admin"
  reviewerRole String   @default("manager")
  version      Int      @default(1)
  isActive     Boolean  @default(true)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdBy  User?          @relation("ReportTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  fields     ReportField[]
  reports    Report[]

  @@index([isActive, name])
  @@index([departmentId])
  @@map("report_template")
}

// A single field within a ReportTemplate. Cascade-deleted with its template.
// configJson holds type-specific config: { options: string[] } for dropdown/
// multi_select; { min, max } for number/short_text/long_text; { maxFiles,
// maxSizeBytes } for file; empty for others.
model ReportField {
  id           String          @id @default(cuid())
  templateId   String
  label        String
  fieldType    ReportFieldType
  helpText     String?
  isRequired   Boolean         @default(false)
  displayOrder Int             @default(0)
  configJson   Json?
  defaultValue String?
  createdAt    DateTime        @default(now())

  template    ReportTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fieldValues ReportFieldValue[]

  @@index([templateId, displayOrder])
  @@map("report_field")
}

// A single staff report submission. templateId pins the exact template version
// used; templateVersion is denormalized for display ("submitted against v2").
model Report {
  id              String       @id @default(cuid())
  templateId      String
  templateVersion Int
  authorId        String
  // Set on first review action (null = not yet picked up by a reviewer).
  reviewerId      String?
  status          ReportStatus @default(draft)
  // FR-REP-9: optional cross-link to a related task.
  taskId          String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  template    ReportTemplate    @relation(fields: [templateId], references: [id], onDelete: Restrict)
  author      User              @relation("ReportAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  reviewer    User?             @relation("ReportReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  task        Task?             @relation(fields: [taskId], references: [id], onDelete: SetNull)
  fieldValues ReportFieldValue[]
  comments    ReportComment[]

  // PRD § 11.3 indexes
  @@index([authorId, status])
  @@index([reviewerId, status])
  @@index([templateId, submittedAt(sort: Desc)])
  @@index([taskId])
  @@map("report")
}

// One value per (report, field) pair. The column used depends on fieldType:
// valueText for short_text/long_text/dropdown, valueNumber for number,
// valueDate for date/datetime, valueJson for multi_select/geolocation/file.
model ReportFieldValue {
  id          String   @id @default(cuid())
  reportId    String
  fieldId     String
  valueText   String?
  valueNumber Decimal?
  valueDate   DateTime?
  valueJson   Json?

  report Report      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  field  ReportField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([reportId, fieldId])
  @@map("report_field_value")
}

// Comments on a report — same lifecycle rules as TaskComment (FR-REP-8):
// author can edit within 15 minutes; deletion is admin-only and logged.
model ReportComment {
  id               String    @id @default(cuid())
  reportId         String
  authorId         String?
  body             String
  mentionedUserIds String[]
  createdAt        DateTime  @default(now())
  editedAt         DateTime?
  deletedAt        DateTime?

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([reportId, createdAt(sort: Desc)])
  @@map("report_comment")
}

// --- Phase 5 — Notifications (FR-NOTIF-1..4) ---

// One row per in-app notification delivery. Rows are never deleted (history
// is the point); readAt marks when the user dismissed it.
model Notification {
  id          String    @id @default(cuid())
  recipientId String
  recipient   User      @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  type        String
  title       String
  body        String
  deepLink    String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([recipientId, readAt, createdAt(sort: Desc)])
  @@index([recipientId, createdAt(sort: Desc)])
  @@map("notification")
}

// Per-user, per-channel, per-category opt-out preferences. Absent row = enabled
// (opt-out model). Written on first explicit user change.
model NotificationPreference {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation("UserNotifPrefs", fields: [userId], references: [id], onDelete: Cascade)
  channel         String    // "in_app" | "email" | "push"
  eventCategory   String    // "task" | "report" | "mention"
  isEnabled       Boolean   @default(true)
  quietHoursStart Int?      // 0-23 inclusive, local time in timeZone
  quietHoursEnd   Int?      // 0-23 inclusive; end < start = crosses midnight
  timeZone        String    @default("UTC")
  pauseUntil      DateTime?

  @@unique([userId, channel, eventCategory])
  @@index([userId])
  @@map("notification_preference")
}

// W3C PushSubscription stored per browser. Self-pruning: stale subscriptions
// (HTTP 410 from push service) are deleted by push.ts on first delivery failure.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserPushSubs", fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  auth      String
  p256dh    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscription")
}

// ADSAT Staff Operations Platform — Phase 1 schema.
// Better Auth canonical tables (User, Account, Session, Verification) are
// generated via `npx @better-auth/cli generate` and merged in below.
// Direct edits to those tables drift from auth config — regenerate instead.

generator client {
	provider      = "prisma-client-js"
	binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
	provider  = "postgresql"
	url       = env("DATABASE_URL")
	directUrl = env("DIRECT_URL")
}

model Department {
	id        String   @id @default(cuid())
	name      String   @unique
	createdAt DateTime @default(now())
	updatedAt DateTime @updatedAt
}
